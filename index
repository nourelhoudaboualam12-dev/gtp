    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand-blue: #4285F4;
            --brand-red: #EA4335;
            --brand-yellow: #FBBC05;
            --brand-green: #34A853;
            --white: #FFFFFF;
            --gray-900: #202124;
            --gray-600: #5f6368;
            --gray-100: #f1f3f4;
            --radius-lg: 24px;
            --shadow-soft: 0 4px 6px rgba(0,0,0,0.05);
            --ease: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--white);
            color: var(--gray-900);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 72px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            display: flex;
            justify-content: center;
            align-items: center;
            border-bottom: 1px solid var(--gray-100);
            z-index: 1000;
        }

        .nav-menu {
            display: flex;
            gap: 40px;
            list-style: none;
        }

        .nav-menu a {
            text-decoration: none;
            color: var(--gray-600);
            font-size: 14px;
            font-weight: 500;
            transition: var(--ease);
        }

        .nav-menu a:hover { color: var(--brand-blue); }

        /* Multi-Page Logic via CSS :target */
        main {
            margin-top: 72px;
            min-height: calc(100vh - 72px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        section {
            display: none;
            width: 100%;
            max-width: 1000px;
            padding: 60px 24px;
            animation: slideUp 0.5s ease-out;
        }

        #home { display: block; text-align: center; }

        #strategy:target, 
        #tag-impl:target, 
        #conv-tracking:target { display: block; }

        /* Hide Home when a sub-page is active */
        :has(#strategy:target) #home,
        :has(#tag-impl:target) #home,
        :has(#conv-tracking:target) #home { display: none; }
        
        /* Fallback for browsers not supporting :has */
        section:target ~ #home { display: none; }

        /* Typography */
        h1 {
            font-size: clamp(2.2rem, 5vw, 3.8rem);
            font-weight: 600;
            letter-spacing: -0.03em;
            margin-bottom: 24px;
            line-height: 1.1;
        }

        .hero-sub {
            font-size: 1.25rem;
            color: var(--gray-600);
            margin-bottom: 48px;
            max-width: 720px;
            margin-left: auto;
            margin-right: auto;
        }

        /* Interactive Elements */
        .actions {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            padding: 14px 32px;
            border-radius: var(--radius-lg);
            font-size: 15px;
            font-weight: 500;
            text-decoration: none;
            transition: var(--ease);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
        }

        .btn-main {
            background-color: var(--brand-blue);
            color: var(--white);
            border: none;
            box-shadow: var(--shadow-soft);
        }

        .btn-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(66, 133, 244, 0.25);
        }

        .btn-back {
            background: transparent;
            border: 1px solid var(--brand-blue);
            color: var(--brand-blue);
            margin-top: 40px;
        }

        .btn-back:hover {
            background: rgba(66, 133, 244, 0.05);
            transform: translateY(-1px);
        }

        /* Content Blocks */
        .card {
            background: var(--white);
            padding: 56px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-100);
            box-shadow: var(--shadow-soft);
        }

        .accent-bar {
            display: flex;
            gap: 6px;
            justify-content: center;
            margin-bottom: 32px;
        }

        .dot { width: 32px; height: 4px; border-radius: 2px; }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        footer {
            margin-top: auto;
            padding: 40px;
            text-align: center;
            font-size: 14px;
            color: var(--gray-600);
            border-top: 1px solid var(--gray-100);
        }

        @media (max-width: 768px) {
            .nav-menu { gap: 20px; }
            section { padding: 40px 20px; }
            .card { padding: 32px; }
        }
    </style>
</head>
<body>

    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <nav>
        <ul class="nav-menu">
            <li><a href="#strategy" id="nav-item-1">Stratégie Analytics</a></li>
            <li><a href="#tag-impl" id="nav-item-2">Implémentation Tags</a></li>
            <li><a href="#conv-tracking" id="nav-item-3">Suivi Conversions</a></li>
        </ul>
    </nav>

    <main>
        <!-- HOME PAGE -->
        <section id="home">
            <div class="accent-bar">
                <div class="dot" style="background: var(--brand-blue);"></div>
                <div class="dot" style="background: var(--brand-red);"></div>
                <div class="dot" style="background: var(--brand-yellow);"></div>
                <div class="dot" style="background: var(--brand-green);"></div>
            </div>
            <h1>Précision Pilotée par les Données : GTM & GA4</h1>
            <p class="hero-sub">Une vitrine professionnelle dédiée à l'architecture Google Tag Manager et au déploiement de stratégies de mesure avancées.</p>
            
            <div class="actions">
                <a href="#strategy" class="btn btn-main" id="btn-strategy">Stratégie Analytics</a>
                <a href="#tag-impl" class="btn btn-main" id="btn-tag">Implémentation GTM</a>
                <a href="#conv-tracking" class="btn btn-main" id="btn-conversion">Suivi de Conversion</a>
            </div>
        </section>

        <!-- SUB-PAGE 1 -->
        <section id="strategy">
            <div class="card">
                <h2 style="color: var(--brand-blue); margin-bottom: 20px;">Stratégie Analytics</h2>
                <p>Définition de plans de marquage complexes alignés sur vos indicateurs de performance clés (KPI). Nous transformons vos objectifs business en architecture technique exploitable dans Google Analytics 4.</p>
                <ul style="margin: 24px 0; color: var(--gray-600); padding-left: 20px;">
                    <li>Audit de la qualité des données existantes.</li>
                    <li>Définition des dimensions et métriques personnalisées.</li>
                    <li>Planification de la gouvernance des données.</li>
                </ul>
                <a href="#" class="btn btn-back">Retour à l'accueil</a>
            </div>
        </section>

        <!-- SUB-PAGE 2 -->
        <section id="tag-impl">
            <div class="card">
                <h2 style="color: var(--brand-green); margin-bottom: 20px;">Implémentation de Tags</h2>
                <p>Déploiement technique de conteneurs GTM avec une gestion avancée du DataLayer. Expertise sur les environnements web, mobiles et les implémentations côté serveur (Server-Side).</p>
                <ul style="margin: 24px 0; color: var(--gray-600); padding-left: 20px;">
                    <li>Configuration de variables JavaScript personnalisées.</li>
                    <li>Mise en place du Consent Mode V2.</li>
                    <li>Optimisation des performances de chargement.</li>
                </ul>
                <a href="#" class="btn btn-back">Retour à l'accueil</a>
            </div>
        </section>

        <!-- SUB-PAGE 3 -->
        <section id="conv-tracking">
            <div class="card">
                <h2 style="color: var(--brand-red); margin-bottom: 20px;">Suivi des Conversions</h2>
                <p>Mesure précise du retour sur investissement (ROI) grâce au suivi e-commerce amélioré et à l'intégration des conversions publicitaires (Google Ads, Meta, LinkedIn).</p>
                <ul style="margin: 24px 0; color: var(--gray-600); padding-left: 20px;">
                    <li>Suivi e-commerce complet (Purchase, AddToCart, ViewItem).</li>
                    <li>Configuration des conversions hors-ligne.</li>
                    <li>Attribution multi-canaux avancée.</li>
                </ul>
                <a href="#" class="btn btn-back">Retour à l'accueil</a>
            </div>
        </section>
    </main>

    <footer>
        Made by Nour - Demo GA4 & GTM
    </footer>

</body>
</html>
